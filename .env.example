# Copy this file to .env and fill in your actual values.
# .env is gitignored — never commit it.
# .env.example is safe to commit — it contains no real credentials.

# Supabase project URL (not a secret — safe to expose)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — bypasses RLS, treat like a password, never expose
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Your user UUID from Supabase Authentication > Users
USER_ID=your-user-uuid-here
